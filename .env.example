# Copy this file to .env and adjust the values.

# Port the server listens on
PORT=3000

# WhatsApp destination for leads. International format, digits only.
# +52 1 55 1059 7019  ->  5215510597019
# When a prospect submits the form they are redirected to a WhatsApp chat
# with this number, pre-filled with all their data.
WHATSAPP_NUMBER=5215510597019

# Comma-separated list of origins allowed to embed / post the form.
# Use "*" to allow any origin (fine while testing, tighten for production).
ALLOWED_ORIGINS=*

# Optional: forward every captured lead to an external URL (CRM, Zapier, Make,
# Google Sheets webhook, etc.) as a JSON POST. Leave empty to disable.
LEAD_WEBHOOK_URL=

# --- Email notifications via Resend (https://resend.com) ---
# When both RESEND_API_KEY and LEAD_NOTIFY_TO are set, every new lead triggers
# an email to the recipient(s). Leave RESEND_API_KEY empty to disable.
RESEND_API_KEY=
# One or more recipient emails, comma-separated.
LEAD_NOTIFY_TO=ventas@ecovalue.mx,otro@ecovalue.mx
# From address. Must be on a domain verified in Resend. For quick testing you
# can use Resend's onboarding sender.
RESEND_FROM=EcoValue Leads <onboarding@resend.dev>

# Optional: simple token required to read/export leads from the admin endpoints.
# Anyone with this token can download the leads, so keep it secret.
ADMIN_TOKEN=change-me

# Optional: where to store leads (JSON + CSV). In production point this at a
# persistent volume so data survives redeploys. On Railway: mount a volume and
# set DATA_DIR to its mount path, e.g. /app/data. Default: ./data
DATA_DIR=
